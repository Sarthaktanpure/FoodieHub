<% layout("/layouts/boilerplate.ejs") %>
<style>
    .social-links a {
        color: white;
    }
</style>
<section class="contact-hero">
  <h1>Get in Touch 🍽️</h1>
  <p>We’d love to hear from you. Whether it's feedback, queries, or collaboration.</p>
</section>

<section class="contact-container">

  <!-- LEFT SIDE FORM -->
  <div class="contact-form-box">
    <h2>Send us a message</h2>

    <form action="/restaurants/contact" novalidate class="needs-validation" method="POST" >

      <input type="text" class="form-control" name="contact[name]" placeholder="Your Name" required>

      <input type="email" class="form-control" name="contact[email]" placeholder="Your Email" required>

      <input type="text" class="form-control" name="contact[subject]" placeholder="Subject" required>

      <textarea name="contact[message]" class="form-control" rows="5" placeholder="Your Message..." required></textarea>

      <button type="submit">Send Message 🚀</button>

    </form>
  </div>

  <!-- RIGHT SIDE INFO -->
  <div class="contact-info">

    <h2>Contact Info</h2>

    <p><strong>👤 Founder:</strong> Sarthak Tanpure</p>
    <p><strong>📧 Email:</strong> sarthaktanpure255@gmail.com</p>
    <p><strong>📍 Location:</strong> Maharashtra, India</p>

    <div class="social-links">
      <a href="https://my-portfolio-sarthak-tanpure.vercel.app/">🌐 Website</a>
      <a href="https://www.linkedin.com/in/sarthak-tanpure-a74b5133a/">💼 LinkedIn</a>
      <a href="https://github.com/Sarthaktanpure">🐙 GitHub</a>
      <a href="https://www.instagram.com/sarthak_tanpure_9290">📸 Instagram</a>
    </div>

  </div>

</section>


<!-- FAQ -->
<section class="contact-faq">

  <h2>Frequently Asked Questions</h2>

  <div class="faq">
    <h4>How can I list my restaurant?</h4>
    <p>You can sign up and add your restaurant through the dashboard.</p>
  </div>

  <div class="faq">
    <h4>Is FoodieHub free?</h4>
    <p>Yes, browsing and discovering restaurants is completely free.</p>
  </div>

  <div class="faq">
    <h4>How does AI recommendation work?</h4>
    <p>We use intelligent logic to suggest restaurants based on your preferences.</p>
  </div>

</section>

<script>
  // Leaflet Map
  const map = L.map('map').setView([19.8762, 75.3433], 13);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap'
  }).addTo(map);

  L.marker([19.8762, 75.3433]).addTo(map)
    .bindPopup("FoodieHub - Aurangabad")
    .openPopup();
</script>

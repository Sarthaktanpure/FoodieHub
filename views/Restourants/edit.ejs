<% layout("/layouts/boilerplate.ejs") %>

    <section class="form-section">

        <div class="form-container">

            <h2>Edit Restaurant</h2>
            <p class="form-subtitle">Update restaurant details.</p>

            <form action="/Restaurants/<%= restaurant._id %>?_method=PUT" novalidate class="needs-validation" method="POST" enctype="multipart/form-data">

                <!-- TITLE -->

                <div class="form-group">
                    <label>Restaurant Name</label>
                    <input type="text" class="form-control" name="restaurant[title]" value="<%= restaurant.title %>" required>
                    <div class="invalid-feedback">
                        Please enter valid Restaurant Name
                    </div>
                </div>

                <!-- DESCRIPTION -->

                <div class="form-group">
                    <label>Description</label>
                    <textarea name="restaurant[description]" class="form-control" required><%= restaurant.description %></textarea>
                    <div class="invalid-feedback">
                        Please enter valid Description
                    </div>
                </div>


                <!-- CUISINE -->

                <div class="form-group">
                    <label>Cuisine</label>
                    <input type="text" class="form-control" name="restaurant[cuisine]" value="<%= restaurant.cuisine %>" required>
                    <div class="invalid-feedback">
                        Please enter valid Cuisine
                    </div>
                </div>

                <!-- PRICE RANGE -->

                <div class="form-group">
                    <label>Price Range</label>

                    <select name="restaurant[priceRange]" class="form-control">

                        <option value="₹" <%=restaurant.priceRange==="₹" ? "selected" : "" %> >₹ Budget</option>

                        <option value="₹₹" <%=restaurant.priceRange==="₹₹" ? "selected" : "" %> >₹₹ Moderate</option>

                        <option value="₹₹₹" <%=restaurant.priceRange==="₹₹₹" ? "selected" : "" %> >₹₹₹ Expensive
                        </option>

                        <option value="₹₹₹₹" <%=restaurant.priceRange==="₹₹₹₹" ? "selected" : "" %> >₹₹₹₹ Luxury
                        </option>

                    </select>
                </div>
                <!-- LOCATION -->

                <div class="form-group">
                    <label>Location</label>
                    <input type="text" class="form-control" name="restaurant[location]" value="<%= restaurant.location %>" required>
                    <div class="invalid-feedback">
                        Please enter valid Location
                    </div>
                </div>


                <!-- IMAGE -->

                <div class="form-group">
                    <label>Image URL</label>
                    <input type="file" class="form-control" name="restaurant[image]" value="<%= restaurant.image.url %>">
                    <div class="invalid-feedack">
                        Please enter valid Image URL
                    </div>
                </div>


                <!-- RATING -->

                <div class="form-group">
                    <label>Rating</label>
                    <input type="number" class="form-control" name="restaurant[rating]" min="1" max="5" step="0.1"
                        value="<%= restaurant.rating %>">
                        <div class="invalid-feedback">
                            Please enter valid Rating
                        </div>
                </div>


                <!-- BUTTONS -->

                <div class="form-actions">

                    <button class="form-btn">
                        Update Restaurant
                    </button>

                    <a href="/restaurants/<%= restaurant._id %>" class="cancel-btn">
                        Cancel
                    </a>

                </div>

            </form>

        </div>

    </section>

    
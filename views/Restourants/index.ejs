<% layout("./layouts/boilerplate.ejs") %>
<section class="hero">
  <div class="hero-container">
    <div class="hero-text">
      <h1>Discover the Best Restaurants Near You</h1>
      <p>Find and review amazing places to eat.</p>

      <div class="search-box">
         <form action="/restaurants/search" method="POST">
          <div class="search-row">
            <input type="text" name="restaurant[cuisine]" placeholder="Cuisine or Dish" />

            <select name="restaurant[location]">
              <option value="">Select Location</option>
              <option>Pune</option>
              <option>Mumbai</option>
              <option>Delhi</option>
              <option>Bangalore</option>
            </select>
          </div>

          <div class="search-row">
            <input
              type="text"
              name="restaurant[restaurant]"
              placeholder="Restaurant Name"
            />

            <button type="submit">Search</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>


    <section class="popular">

        <h2>Popular Restaurants</h2>

        <div class="restaurant-grid">

            <% for(let data of allData){ %>
               <a href="/Restaurants/<%= data._id  %>" class="index-anchor">

                <div class="card">

                    <% if (data.image && data.image.url) { %>
                        <img src="<%= data.image.url %>" alt="<%= data.title %>">
                    <% } %>

                    <div class="card-content">

                        <h3>
                            <%= data.title %>
                        </h3>

                        <p>
                            <%= data.location %>
                        </p>

                    </div>

                </div>
                </a>

                <% } %>

        </div>

    </section>

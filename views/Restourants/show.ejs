<% layout("/layouts/boilerplate.ejs") %>
  <section class="restaurant-show">
    <div class="show-container">
      <!-- IMAGE SECTION -->

      <div class="show-image">
        <img src="<%= restaurant.image.url %>" alt="<%= restaurant.title %>" />
      </div>

      <!-- DETAILS SECTION -->

      <div class="show-details">
        <h1 class="restaurant-title">
          <%= restaurant.title %>
        </h1>

        <p class="restaurant-description">
          <%= restaurant.description %>
        </p>

        <div class="restaurant-meta">
          <span class="tag cuisine">
            <%= restaurant.cuisine %>
          </span>

          <span class="tag price">
            <%= restaurant.priceRange %>
          </span>

          <span class="tag location">
            <%= restaurant.location %>
          </span>
        </div>

        <div class="rating-box">
          <strong>
            <%= restaurant.rating || "No rating yet" %>
          </strong> / 5
        </div>

        <% if (currUser && restaurant.owner && currUser._id.equals(restaurant.owner._id || restaurant.owner)) { %>
          <div class="show-actions">
          <a href="/restaurants/<%= restaurant._id %>/edit" class="edit-btn">
            Edit
          </a>
          <form action="/restaurants/<%= restaurant._id %>?_method=DELETE" method="POST">
            <button class="delete-btn">Delete</button>
          </form>
        </div>
          <% } %>

      </div>
    </div>
  </section>

  <% const coords = restaurant.geometry && restaurant.geometry.coordinates; %>
  <section class="map-section">
    <div class="show-container">
      <h2 class="map-heading">Location</h2>
      <% if (coords && coords.length === 2) { %>
        <div
          id="restaurant-map"
          data-lng="<%= coords[0] %>"
          data-lat="<%= coords[1] %>"
          data-title="<%= restaurant.title %>"
        ></div>
      <% } else { %>
        <p class="map-fallback">Location coordinates not available.</p>
      <% } %>
    </div>
  </section>

  <!-- COMMENTS SECTION -->
  <section class="comments-section">

    <div class="comments-container">

      <h2 class="comment-heading">Reviews </h2>

      <!-- ADD COMMENT FORM -->
      <div class="comment-form-box">
        <form action="/restaurants/<%= restaurant._id %>/reviews" method="POST">

          <textarea name="review[comment]" placeholder="Write your review..." required></textarea>

          <div class="comment-actions">
            <label for=""></label>
            <fieldset class="starability-basic">
              <legend>Add Ratings</legend>
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked
                aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>

            <button class="comment-btn">Post</button>
          </div>

        </form>
      </div>

      <!-- ALL COMMENTS -->
      <div class="comments-list">

  <% if (restaurant.reviews && restaurant.reviews.length > 0) { %>

    <% for (let review of restaurant.reviews) { %>

      <div class="comment-card">

        <div class="comment-top">
          <span class="comment-user">
            @<%= (review.author && review.author.username) ? review.author.username : "Anonymous" %>
          </span>

                <p class="starability-result" data-rating="<%= review.rating  %>"></p>
  
        </div>

        <p class="comment-text">
          <%= review.comment %>
        </p>

        <% if (currUser && review.author && currUser._id.equals(review.author._id || review.author)) { %>
          <div class="comment-actions">
            <form action="/restaurants/<%= restaurant._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
              <button class="delete-review-btn">Delete</button>
            </form>
          </div>
        <% } %>

      </div>

    <% } %>

  <% } else { %>

    <p class="no-comments">No reviews yet. Be the first one ðŸš€</p>

  <% } %>

</div>

    </div>

  </section>

  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
  ></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const mapEl = document.getElementById("restaurant-map");
      if (!mapEl) return;

      const lat = parseFloat(mapEl.dataset.lat);
      const lng = parseFloat(mapEl.dataset.lng);
      if (Number.isNaN(lat) || Number.isNaN(lng)) return;

      const map = L.map(mapEl, {
        zoomControl: true,
        scrollWheelZoom: false,
      }).setView([lat, lng], 13);

      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: "&copy; OpenStreetMap contributors",
      }).addTo(map);

      const title = mapEl.dataset.title || "Restaurant";
      L.marker([lat, lng]).addTo(map).bindPopup(title);
    });
  </script>
